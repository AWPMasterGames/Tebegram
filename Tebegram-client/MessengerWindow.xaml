<Window
    x:Class="Tebegrammmm.MessengerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tebegrammmm"
    xmlns:local1="clr-namespace:Tebegrammmm.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tebegram"
    Width="800"
    Height="550"
    MinWidth="600"
    MinHeight="350"
    Closing="Window_Closing"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  Левая панель  -->
        <Grid Background="#303c4c">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Button
                Height="50"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Settings"
                Content="☰"
                FontSize="30"
                Foreground="Gray" />
            <ListBox
                x:Name="LBChatsLoders"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectionChanged="LBChatsLoders_SelectionChangeFolder">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="25"
                                    Foreground="Gray"
                                    Text="{Binding Icon}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="15"
                                    Foreground="Gray"
                                    Text="{Binding FolderName}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Row="2">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        Foreground="Gray"
                        Text="⚒" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="Gray"
                        Text="Ред." />
                </StackPanel>
                <Button
                    Height="50"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="Button_Click_FoldersMenu"
                    Content=""
                    FontSize="15" />
            </Grid>
        </Grid>
        <!--  Чаты  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="10,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBox
                    Name="SearchContactBarTB"
                    Width="165"
                    Height="35"
                    Margin="0,0,25,0"
                    FontSize="20"
                    Template="{StaticResource TextBoxBaseControlTemplate}"
                    TextChanged="TextBox_TextChanged"
                    TextWrapping="Wrap" />
                <Button
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="Button_Click_AddContact">
                    <Border
                        Width="35"
                        Height="35"
                        BorderBrush="Gray"
                        BorderThickness="2"
                        CornerRadius="20">
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Margin="0,-2,0,0"
                                FontSize="20"
                                Foreground="RoyalBlue"
                                Text="⁺" />
                            <TextBlock
                                Margin="3,3,0,0"
                                FontSize="17"
                                Foreground="RoyalBlue"
                                Text="👤" />

                        </Grid>
                    </Border>
                </Button>
            </StackPanel>
            <ListBox
                x:Name="LBChats"
                Grid.Row="2"
                SelectionChanged="LBChats_SelectionChangedChat">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="50">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <local1:UserControl1 Grid.RowSpan="2" Avatar="https://djnkpzmq-5000.euw.devtunnels.ms/avatars/1008024429709774919.webp" />
                            <TextBlock
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Width="165"
                                Height="50"
                                Margin="10,0"
                                FontSize="15"
                                Text="{Binding Name}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <!--  Чат  -->
        <Border
            Grid.Column="2"
            BorderBrush="Black"
            BorderThickness="0.2">

            <Grid x:Name="GridChat">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition />
                    <RowDefinition Height="65" />
                </Grid.RowDefinitions>
                <Grid Name="GridContactPanel" Margin="10,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Name="TBChat_Name"
                        Margin="10,0"
                        FontSize="15"
                        Text="{Binding Name}" />
                    <TextBlock
                        Name="TBChat_Status"
                        Grid.Row="1"
                        Margin="10,0"
                        FontSize="12"
                        Foreground="Gray"
                        Text=""
                        Visibility="Collapsed" />

                    <StackPanel
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Margin="5,-2,5,0"
                        Orientation="Horizontal">
                        <Button
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_CallContact">
                            <Border
                                Width="35"
                                Height="35"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                CornerRadius="20">
                                <Grid HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Width="21"
                                        Margin="0,-10,0,0"
                                        HorizontalAlignment="Left"
                                        FontSize="30"
                                        Foreground="RoyalBlue"
                                        Text=" 🕻" />

                                </Grid>
                            </Border>
                        </Button>
                        <Button
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_RemoveContact">
                            <Border
                                Width="35"
                                Height="35"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                CornerRadius="20">
                                <Grid HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Margin="-5,-2,0,0"
                                        FontSize="10"
                                        Foreground="red"
                                        Text="🗑" />
                                    <TextBlock
                                        Margin="3,3,0,0"
                                        FontSize="17"
                                        Foreground="RoyalBlue"
                                        Text="👤" />

                                </Grid>
                            </Border>
                        </Button>
                        <Button
                            Width="40"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_ContactRedact">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="30"
                                Text="⋮" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ListBox
                    x:Name="LBMessages"
                    Grid.Row="1"
                    SelectionChanged="LBMessages_SelectionChangeMessage">
                    <ListBox.Background>
                        <StaticResource ResourceKey="ChatBackground" />
                    </ListBox.Background>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="25">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="LightGray" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background" Value="LightCoral" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Width="250" Margin="10,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Margin="5,0"
                                        Foreground="#FF4200FF"
                                        Text="{Binding Sender}" />
                                    <Image Grid.Row="1" Source="{Binding ServerAdress}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Margin="5,0"
                                        FontSize="15"
                                        Text="{Binding Text}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Row="3"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        FontSize="10"
                                        Foreground="#FF7D7D7D"
                                        Text="{Binding Time}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
                <Grid x:Name="GridMessege" Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Width="40"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="Button_Click_SelectFile"
                        Content="📄"
                        FontSize="20" />
                    <ScrollViewer Grid.Column="1" Margin="10">
                        <TextBox
                            x:Name="TBMessage"
                            FontSize="15"
                            KeyDown="TBMessage_KeyDown_SendMessage"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                    <Button
                        Grid.Column="2"
                        Width="40"
                        Margin="10"
                        Background="Transparent"
                        Click="Button_Click_SendMessage"
                        Content="⌯⌲" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
