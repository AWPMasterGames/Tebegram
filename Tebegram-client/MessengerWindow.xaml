<Window
    x:Class="Tebegrammmm.MessengerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tebegrammmm"
    xmlns:local1="clr-namespace:Tebegrammmm.Controls"
    xmlns:classes="clr-namespace:Tebegrammmm.Classes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tebegrammmm"
    Width="800"
    Height="550"
    MinWidth="600"
    MinHeight="350"
    Background="{DynamicResource Light.BgDeepBrush}"
    Closing="Window_Closing"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>

        <!--  Тонкий скроллбар для всего окна  -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5" />
            <Setter Property="MinWidth" Value="5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Width="5">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="True"
                                Margin="0,4">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border
                                                    Margin="1,0"
                                                    Background="{DynamicResource Light.BorderStrongBrush}"
                                                    CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Width" Value="Auto" />
                                <Setter TargetName="Root" Property="Height" Value="5" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="5" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <classes:ImageUrlConverter x:Key="ImageUrlConverter" />
        <classes:TimeFormatConverter x:Key="TimeFormatConverter" />

        <ControlTemplate x:Key="RoundIconButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Background="{TemplateBinding Background}"
                CornerRadius="999">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.62" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="250" MinWidth="62" MaxWidth="360" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!--  Левая панель  -->
        <Grid Background="{DynamicResource Light.BgSurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Button
                Height="50"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Settings">
                <Viewbox Width="22" Height="22">
                    <Path Data="{StaticResource IconSettings}" Fill="{DynamicResource Light.TextSecondaryBrush}" />
                </Viewbox>
            </Button>
            <!--  Статическая папка "Все чаты"  -->
            <Button
                Grid.Row="1"
                x:Name="BtnAllChats"
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="4"
                Click="BtnAllChats_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconChat}" Fill="{DynamicResource Light.TextSecondaryBrush}" />
                    </Viewbox>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource Light.TextSecondaryBrush}"
                        Text="Все чаты" />
                </StackPanel>
            </Button>

            <ListBox
                x:Name="LBChatsLoders"
                Grid.Row="2"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectionChanged="LBChatsLoders_SelectionChangeFolder">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.AccentMutedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Center">
                            <Viewbox
                                Width="22"
                                Height="22"
                                HorizontalAlignment="Center">
                                <Path Data="{StaticResource IconChat}" Fill="{DynamicResource Light.TextSecondaryBrush}" />
                            </Viewbox>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{DynamicResource Light.TextSecondaryBrush}"
                                Text="{Binding FolderName}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button
                Grid.Row="3"
                Height="50"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_FoldersMenu">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Viewbox Width="22" Height="22">
                    <Path Data="{StaticResource IconInfo}" Fill="{DynamicResource Light.TextSecondaryBrush}" />
                </Viewbox>
            </Button>
        </Grid>

        <!--  Список чатов  -->
        <Grid
            x:Name="ChatListContainer"
            Grid.Column="1"
            ClipToBounds="True"
            Background="{DynamicResource Light.BgPrimaryBrush}"
            SizeChanged="ChatListContainer_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid x:Name="SearchArea" Margin="8,0">
                <TextBox
                    Name="SearchContactBarTB"
                    Height="35"
                    Background="{DynamicResource Light.BgInputBrush}"
                    FontSize="14"
                    Foreground="{DynamicResource Light.TextPrimaryBrush}"
                    Template="{StaticResource TextBoxBaseControlTemplate}"
                    TextChanged="TextBox_TextChanged"
                    TextWrapping="Wrap" />
            </Grid>
            <Button
                x:Name="BtnAddNarrow"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_AddContact"
                Visibility="Collapsed">
                <Viewbox Width="20" Height="20">
                    <Path Data="{StaticResource IconAddUser}" Fill="{DynamicResource Light.AccentTextBrush}" />
                </Viewbox>
            </Button>
            <ListBox
                x:Name="LBChats"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectionChanged="LBChats_SelectionChangedChat" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="6,4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Light.AccentMutedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="50">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <local1:UserControl1
                                Grid.RowSpan="2"
                                Width="44"
                                Height="44"
                                Avatar="{Binding Avatar}" />
                            <TextBlock
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Height="50"
                                Margin="10,0"
                                FontSize="15"
                                Foreground="{DynamicResource Light.TextPrimaryBrush}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="narrow">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

        <!--  Ресайз-разделитель колонки чатов  -->
        <GridSplitter
            Grid.Column="1"
            Width="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Background="Transparent"
            Cursor="SizeWE"
            ResizeBehavior="CurrentAndNext"
            ResizeDirection="Columns" />

        <!--  Область чата  -->
        <Border
            Grid.Column="2"
            BorderBrush="{DynamicResource Light.BorderSubtleBrush}"
            BorderThickness="1,0,0,0">
            <Grid x:Name="GridChat">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition />
                    <RowDefinition Height="65" />
                </Grid.RowDefinitions>

                <!--  Шапка чата  -->
                <Border
                    Background="{DynamicResource Light.BgSurfaceBrush}"
                    BorderBrush="{DynamicResource Light.BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid Name="GridContactPanel" Margin="10,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <local1:UserControl1
                            Grid.RowSpan="2"
                            Width="36"
                            Height="36"
                            Margin="0,0,10,0"
                            Avatar="{Binding Avatar}" />
                        <TextBlock
                            Grid.Column="1"
                            Name="TBChat_Name"
                            Margin="0,0,10,0"
                            FontSize="15"
                            Foreground="{DynamicResource Light.TextPrimaryBrush}"
                            Text="{Binding Name}" />
                        <StackPanel
                            Grid.RowSpan="2"
                            Grid.Column="2"
                            Margin="5,-2,5,0"
                            Orientation="Horizontal">
                            <Button
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_CallContact">
                                <Border
                                    Width="35"
                                    Height="35"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="20">
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="{StaticResource IconPhone}" Fill="{DynamicResource Light.AccentTextBrush}" />
                                    </Viewbox>
                                </Border>
                            </Button>
                            <Button
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_RemoveContact">
                                <Border
                                    Width="35"
                                    Height="35"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="20">
                                    <Viewbox Width="18" Height="18">
                                        <Path Data="{StaticResource IconRemoveUser}" Fill="{DynamicResource Light.DangerBrush}" />
                                    </Viewbox>
                                </Border>
                            </Button>
                            <Button
                                Width="40"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_ContactRedact">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="{StaticResource IconList}" Fill="{DynamicResource Light.TextSecondaryBrush}" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Оверлей загрузки (виден до получения истории с сервера)  -->
                <Border
                    x:Name="MessagesLoadingOverlay"
                    Grid.Row="1"
                    Panel.ZIndex="1"
                    Background="{DynamicResource Light.BgPrimaryBrush}"
                    Visibility="Visible">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Foreground="{DynamicResource Light.TextMutedBrush}"
                        Text="Загрузка…" />
                </Border>

                <!--  Сообщения  -->
                <ListBox
                    x:Name="LBMessages"
                    Grid.Row="1"
                    BorderThickness="0"
                    Padding="12,8"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionChanged="LBMessages_SelectionChangeMessage"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.Background>
                        <StaticResource ResourceKey="ChatBackgroundLight" />
                    </ListBox.Background>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,3" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--  Пузырь сообщения  -->
                            <Border MaxWidth="380" ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource Light.MsgIncomingBrush}" />
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="CornerRadius" Value="4,14,14,14" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="Background" Value="{DynamicResource Light.MsgOutgoingBrush}" />
                                                <Setter Property="CornerRadius" Value="14,4,14,14" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="{DynamicResource Light.MsgPendingBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background" Value="{DynamicResource Light.MsgFailedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="6"
                                        Opacity="0.08"
                                        ShadowDepth="1"
                                        Color="#000000" />
                                </Border.Effect>

                                <StackPanel Margin="0">
                                    <!--  Имя отправителя (скрыто для исходящих)  -->
                                    <TextBlock
                                        Margin="12,8,12,3"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Light.AccentTextBrush}"
                                        Text="{Binding Sender}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!--  Изображение + время поверх (только для Image)  -->
                                    <Grid Loaded="ImageContainer_Loaded">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MessageType}" Value="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Скачать" Click="ImageContextMenu_Download" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Image
                                            MaxHeight="320"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{Binding ServerAdress, Converter={StaticResource ImageUrlConverter}}"
                                            Stretch="Uniform" />
                                        <!--  Время поверх фото  -->
                                        <Border
                                            Margin="0,0,8,8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Background="#88000000"
                                            CornerRadius="10"
                                            Padding="6,2">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="White"
                                                Text="{Binding Time, Converter={StaticResource TimeFormatConverter}}" />
                                        </Border>
                                    </Grid>

                                    <!--  Текст сообщения  -->
                                    <TextBlock
                                        Margin="12,8,12,0"
                                        FontSize="14"
                                        Text="{Binding Text}"
                                        TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Light.TextPrimaryBrush}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MessageType}" Value="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!--  Время (только для текстовых сообщений)  -->
                                    <TextBlock
                                        Margin="12,4,12,8"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        Text="{Binding Time, Converter={StaticResource TimeFormatConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Light.TextMutedBrush}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                                        <Setter Property="Foreground" Value="#CCFFFFFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MessageType}" Value="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--  Поле ввода  -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource Light.BgSurfaceBrush}"
                    BorderBrush="{DynamicResource Light.BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="10,8">
                    <Grid x:Name="GridMessege" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Прикрепить файл  -->
                        <Button
                            Width="34"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="{DynamicResource Light.BgElevatedBrush}"
                            Click="Button_Click_SelectFile"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Прикрепить файл">
                            <Viewbox Width="16" Height="16">
                                <Path
                                    Data="{StaticResource IconAttach}"
                                    Fill="{DynamicResource Light.TextSecondaryBrush}"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Button>

                        <!--  Поле ввода текста  -->
                        <Border
                            Grid.Column="1"
                            Background="{DynamicResource Light.BgInputBrush}"
                            BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,6">
                            <ScrollViewer
                                MaxHeight="72"
                                VerticalAlignment="Center"
                                VerticalScrollBarVisibility="Auto">
                                <TextBox
                                    x:Name="TBMessage"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{DynamicResource Light.TextPrimaryBrush}"
                                    KeyDown="TBMessage_KeyDown_SendMessage"
                                    TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>

                        <!--  Отправить  -->
                        <Button
                            Grid.Column="2"
                            Width="34"
                            Height="34"
                            Margin="8,0,0,0"
                            Background="{DynamicResource Light.AccentPrimaryBrush}"
                            Click="Button_Click_SendMessage"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Отправить">
                            <Viewbox Width="15" Height="15">
                                <Path
                                    Data="{StaticResource IconSend}"
                                    Fill="White"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Button>

                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
