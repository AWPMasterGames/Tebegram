<Window
    x:Class="Tebegrammmm.MessengerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tebegrammmm"
    xmlns:local1="clr-namespace:Tebegrammmm.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Tebegrammmm"
    Width="800"
    Height="550"
    MinWidth="600"
    MinHeight="350"
    Background="{StaticResource Light.BgDeepBrush}"
    Closing="Window_Closing"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>

        <!--  Тонкий скроллбар для всего окна  -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5" />
            <Setter Property="MinWidth" Value="5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Width="5">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="True"
                                Margin="0,4">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border
                                                    Margin="1,0"
                                                    Background="{StaticResource Light.BorderStrongBrush}"
                                                    CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Width" Value="Auto" />
                                <Setter TargetName="Root" Property="Height" Value="5" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="5" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="RoundIconButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Background="{TemplateBinding Background}"
                CornerRadius="999">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.62" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!--  Левая панель  -->
        <Grid Background="{StaticResource Light.BgSurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Button
                Height="50"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Settings">
                <Viewbox Width="22" Height="22">
                    <Path Data="{StaticResource IconSettings}" Fill="{StaticResource Light.TextSecondaryBrush}" />
                </Viewbox>
            </Button>
            <ListBox
                x:Name="LBChatsLoders"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectionChanged="LBChatsLoders_SelectionChangeFolder">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Light.BgElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource Light.AccentMutedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="25"
                                Foreground="{StaticResource Light.TextSecondaryBrush}"
                                Text="{Binding Icon}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="{StaticResource Light.TextSecondaryBrush}"
                                Text="{Binding FolderName}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Row="2">
                <Viewbox
                    Width="22"
                    Height="22"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
                    <Path Data="{StaticResource IconInfo}" Fill="{StaticResource Light.TextSecondaryBrush}" />
                </Viewbox>
                <Button
                    Height="50"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="Button_Click_FoldersMenu"
                    Content=""
                    FontSize="15" />
            </Grid>
        </Grid>

        <!--  Список чатов  -->
        <Grid Grid.Column="1" Background="{StaticResource Light.BgPrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="10,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBox
                    Name="SearchContactBarTB"
                    Width="165"
                    Height="35"
                    Margin="0,0,25,0"
                    Background="{StaticResource Light.BgInputBrush}"
                    FontSize="20"
                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                    Template="{StaticResource TextBoxBaseControlTemplate}"
                    TextChanged="TextBox_TextChanged"
                    TextWrapping="Wrap" />
                <Button
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="Button_Click_AddContact">
                    <Border
                        Width="35"
                        Height="35"
                        BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                        BorderThickness="0"
                        CornerRadius="20">
                        <Viewbox Width="18" Height="18">
                            <Path Data="{StaticResource IconAddUser}" Fill="{StaticResource Light.AccentTextBrush}" />
                        </Viewbox>
                    </Border>
                </Button>
            </StackPanel>
            <ListBox
                x:Name="LBChats"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="Transparent"
                SelectionChanged="LBChats_SelectionChangedChat" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="6,4" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Light.BgElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource Light.AccentMutedBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="50">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <local1:UserControl1 Grid.RowSpan="2" Avatar="https://djnkpzmq-5000.euw.devtunnels.ms/avatars/1008024429709774919.webp" />
                            <TextBlock
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Height="50"
                                Margin="10,0"
                                FontSize="15"
                                Foreground="{StaticResource Light.TextPrimaryBrush}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!--  Область чата  -->
        <Border
            Grid.Column="2"
            BorderBrush="{StaticResource Light.BorderSubtleBrush}"
            BorderThickness="1,0,0,0">
            <Grid x:Name="GridChat">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition />
                    <RowDefinition Height="65" />
                </Grid.RowDefinitions>

                <!--  Шапка чата  -->
                <Border
                    Background="{StaticResource Light.BgSurfaceBrush}"
                    BorderBrush="{StaticResource Light.BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid Name="GridContactPanel" Margin="10,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Name="TBChat_Name"
                            Margin="10,0"
                            FontSize="15"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            Text="{Binding Name}" />
                        <StackPanel
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Margin="5,-2,5,0"
                            Orientation="Horizontal">
                            <Button
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_CallContact">
                                <Border
                                    Width="35"
                                    Height="35"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="20">
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="{StaticResource IconPhone}" Fill="{StaticResource Light.AccentTextBrush}" />
                                    </Viewbox>
                                </Border>
                            </Button>
                            <Button
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_RemoveContact">
                                <Border
                                    Width="35"
                                    Height="35"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="20">
                                    <Viewbox Width="18" Height="18">
                                        <Path Data="{StaticResource IconRemoveUser}" Fill="{StaticResource Light.DangerBrush}" />
                                    </Viewbox>
                                </Border>
                            </Button>
                            <Button
                                Width="40"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_ContactRedact">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="{StaticResource IconList}" Fill="{StaticResource Light.TextSecondaryBrush}" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Сообщения  -->
                <ListBox
                    x:Name="LBMessages"
                    Grid.Row="1"
                    BorderThickness="0"
                    Padding="12,8"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionChanged="LBMessages_SelectionChangeMessage"
                    VirtualizingPanel.ScrollUnit="Pixel"
                    d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.Background>
                        <StaticResource ResourceKey="ChatBackgroundLight" />
                    </ListBox.Background>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,3" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--  Пузырь сообщения  -->
                            <Border
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                CornerRadius="4,14,14,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Light.MsgIncomingBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="{StaticResource Light.MsgPendingBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background" Value="{StaticResource Light.MsgFailedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="6"
                                        Opacity="0.08"
                                        ShadowDepth="1"
                                        Color="#000000" />
                                </Border.Effect>

                                <StackPanel Margin="12,8">
                                    <!--  Имя отправителя  -->
                                    <TextBlock
                                        Margin="0,0,0,3"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource Light.AccentTextBrush}"
                                        Text="{Binding Sender}" />
                                    <!--  Вложение (файл/изображение)  -->
                                    <Image
                                        MaxHeight="200"
                                        Margin="0,0,0,4"
                                        Source="{Binding ServerAdress}"
                                        Stretch="UniformToFill" />
                                    <!--  Текст сообщения  -->
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{StaticResource Light.TextPrimaryBrush}"
                                        Text="{Binding Text}"
                                        TextWrapping="Wrap" />
                                    <!--  Время  -->
                                    <TextBlock
                                        Margin="0,5,0,0"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        Foreground="{StaticResource Light.TextMutedBrush}"
                                        Text="{Binding Time}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--  Поле ввода  -->
                <Border
                    Grid.Row="2"
                    Background="{StaticResource Light.BgSurfaceBrush}"
                    BorderBrush="{StaticResource Light.BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="10,8">
                    <Grid x:Name="GridMessege" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Прикрепить файл  -->
                        <Button
                            Width="34"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="{StaticResource Light.BgElevatedBrush}"
                            Click="Button_Click_SelectFile"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Прикрепить файл">
                            <Viewbox Width="16" Height="16">
                                <Path
                                    Data="{StaticResource IconAttach}"
                                    Fill="{StaticResource Light.TextSecondaryBrush}"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Button>

                        <!--  Поле ввода текста  -->
                        <Border
                            Grid.Column="1"
                            Background="{StaticResource Light.BgInputBrush}"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,6">
                            <ScrollViewer
                                MaxHeight="72"
                                VerticalAlignment="Center"
                                VerticalScrollBarVisibility="Auto">
                                <TextBox
                                    x:Name="TBMessage"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="TBMessage_KeyDown_SendMessage"
                                    TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>

                        <!--  Отправить  -->
                        <Button
                            Grid.Column="2"
                            Width="34"
                            Height="34"
                            Margin="8,0,0,0"
                            Background="{StaticResource Light.AccentPrimaryBrush}"
                            Click="Button_Click_SendMessage"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Отправить">
                            <Viewbox Width="15" Height="15">
                                <Path
                                    Data="{StaticResource IconSend}"
                                    Fill="White"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Button>

                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
