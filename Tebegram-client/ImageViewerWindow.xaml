<Window
    x:Class="Tebegrammmm.ImageViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowsTransparency="True"
    Background="Transparent"
    MinWidth="400"
    MinHeight="300"
    MouseDown="Window_MouseDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ControlTemplate x:Key="RoundIconButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Background="{TemplateBinding Background}"
                CornerRadius="999">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.62" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <Border
            Background="#1A1A1A"
            CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="30"
                    Opacity="0.5"
                    ShadowDepth="6"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Верхняя панель  -->
                <Grid Grid.Row="0" Margin="16,0,8,0">
                    <TextBlock
                        x:Name="TitleText"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#CCFFFFFF"
                        TextTrimming="CharacterEllipsis" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="32"
                            Height="32"
                            Click="MinimizeBtn_Click"
                            Content="─"
                            FontSize="13"
                            Foreground="#99FFFFFF"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Свернуть" />
                        <Button
                            Width="32"
                            Height="32"
                            Margin="2,0,0,0"
                            Click="CloseBtn_Click"
                            Content="✕"
                            FontSize="13"
                            Foreground="#99FFFFFF"
                            Template="{StaticResource RoundIconButtonTemplate}"
                            ToolTip="Закрыть" />
                    </StackPanel>
                </Grid>

                <!--  Изображение  -->
                <ScrollViewer
                    Grid.Row="1"
                    Margin="12,0,12,12"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!--  Спиннер загрузки  -->
                        <TextBlock
                            x:Name="LoadingText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#66FFFFFF"
                            Text="Загрузка..." />

                        <Image
                            x:Name="MainImage"
                            MaxWidth="1600"
                            MaxHeight="1200"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Stretch="Uniform"
                            Visibility="Collapsed" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
