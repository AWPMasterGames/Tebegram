<Window x:Class="Tebegrammmm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Opacity="1"
        MouseDown="Window_MouseDown">

    <Grid>
       
        <!--Основной Grid, не трогать!!!-->


        <!-- Экран логина -->
        <Grid Visibility="Visible" x:Name="LoginGrid" Grid.RowSpan="2" Width="400" Height="400">
            <Border CornerRadius="20"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF3C3C3C"
                    BorderThickness="2"
                    Padding="20">
                <Grid>
                    <Button Content="X"
                            Width="30" Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-13,-13,0"
                            Background="#FF3C3C3C"
                            Foreground="White"
                            BorderBrush="{x:Null}"
                            FontWeight="Bold"
                            FontSize="14"
                            Click="CloseButton_Click"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Login"
                                   FontSize="28"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 30" />

                        <TextBlock Text="Username" Foreground="LightGray"/>
                        <TextBox x:Name="TBUserLogin"
                                 Height="35"
                                 Margin="0 5 0 15"
                                 FontSize="15"
                                 Background="#FF2D2D30"
                                 Foreground="White"
                                 BorderBrush="#FF3C3C3C"
                                 KeyDown="TextBox_KeyDown"/>

                        <TextBlock Text="Password" Foreground="LightGray"/>
                        <PasswordBox x:Name="PBUserPassord"
                                     Height="35"
                                     Margin="0 5 0 25"
                                     FontSize="14"
                                     Background="#FF2D2D30"
                                     Foreground="White"
                                     BorderBrush="#FF3C3C3C"
                                     KeyDown="TBUserPassord_KeyDown"/>

                        <Button x:Name="LoginButton"
                                Content="Login"
                                Height="40"
                                Background="#FF007ACC"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="16"
                                Margin="0 0 0 10"
                                Click="Button_Click"/>

                        <Button x:Name="RegisterButton"
                                Content="Register"
                                Height="35"
                                Background="Transparent"
                                Foreground="LightGray"
                                FontSize="14"
                                BorderBrush="#FF3C3C3C"
                                Click="RegisterButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Экран регистрации -->
        <Grid Visibility="Hidden" x:Name="RegistrationGrid" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="416*"/>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="0*"/>
            </Grid.RowDefinitions>
            <Border x:Name="RegistrationBorder"
                    CornerRadius="20"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF3C3C3C"
                    BorderThickness="2"
                    Padding="20" Grid.RowSpan="4" Height="500" VerticalAlignment="Top">
                <Grid>
                    <Button Content="X"
                            Width="30" Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-13,-13,0"
                            Background="#FF3C3C3C"
                            Foreground="White"
                            BorderBrush="{x:Null}"
                            FontWeight="Bold"
                            FontSize="14"
                            Click="CloseButton_Click"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Registration"
                                   FontSize="28"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 30" />

                        <TextBlock Text="Name" Foreground="LightGray"/>
                        <TextBox x:Name="TBUserName"
                                 Height="35"
                                 Margin="0 5 0 15"
                                 FontSize="15"
                                 Background="#FF2D2D30"
                                 Foreground="White"
                                 BorderBrush="#FF3C3C3C"
                                 KeyDown="TextBox_KeyDown"/>

                        <TextBlock Text="Username" Foreground="LightGray"/>
                        <TextBox x:Name="TBUserNameLogin"
                                 Height="35"
                                 Margin="0 5 0 15"
                                 FontSize="15"
                                 Background="#FF2D2D30"
                                 Foreground="White"
                                 BorderBrush="#FF3C3C3C"
                                 KeyDown="TextBox_KeyDown"/>

                        <TextBlock Text="Password" Foreground="LightGray"/>
                        <PasswordBox x:Name="PBUserPassword"
                                     Height="35"
                                     Margin="0 5 0 15"
                                     FontSize="14"
                                     Background="#FF2D2D30"
                                     Foreground="White"
                                     BorderBrush="#FF3C3C3C"
                                     KeyDown="PasswordBox_KeyDown"/>

                        <TextBlock Text="Confirm Password" Foreground="LightGray"/>
                        <PasswordBox x:Name="PBUserPasswordConfirm"
                                     Height="35"
                                     Margin="0 5 0 25"
                                     FontSize="14"
                                     Background="#FF2D2D30"
                                     Foreground="White"
                                     BorderBrush="#FF3C3C3C"
                                     KeyDown="PasswordBox_KeyDown"/>

                        <Button x:Name="DoRegisterButton"
                                Content="Register"
                                Height="40"
                                Background="#FF007ACC"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="16"
                                Margin="0 0 0 10"
                                Click="DoRegisterButton_Click"/>

                        <Button x:Name="BackButton"
                                Content="Back to Login"
                                Height="35"
                                Background="Transparent"
                                Foreground="LightGray"
                                FontSize="14"
                                BorderBrush="#FF3C3C3C"
                                Click="BackButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
