<Window
    x:Class="Tebegrammmm.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Авторизация"
    Width="400"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    Opacity="1"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>

        <!-- Поле ввода без рамки — для PasswordBox и TextBox внутри кастомного контейнера -->
        <ControlTemplate x:Key="InnerPasswordBox" TargetType="PasswordBox">
            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="8,0,0,0" />
        </ControlTemplate>
        <ControlTemplate x:Key="InnerTextBox" TargetType="TextBox">
            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="8,0,0,0" />
        </ControlTemplate>

        <!-- Кнопка глаза: прозрачная, только иконка -->
        <ControlTemplate x:Key="EyeButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Кнопка закрытия: прозрачная → красная при наведении -->
        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Основная кнопка со скруглением и hover -->
        <ControlTemplate x:Key="PrimaryButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.AccentPressedBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Вторичная кнопка со скруглением и hover -->
        <ControlTemplate x:Key="SecondaryButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Background="Transparent"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgElevatedBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </Window.Resources>

    <Grid Background="Transparent">

        <!--  Экран логина  -->
        <Grid
            x:Name="LoginGrid"
            Visibility="Visible">
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="LoginCloseBtn"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="LoginCloseBtn"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            <Border
                Padding="20"
                Background="{StaticResource Light.BgPrimaryBrush}"
                BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Button
                        x:Name="LoginCloseBtn"
                        Width="28"
                        Height="28"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"
                        Content="✕"
                        FontSize="14"
                        Opacity="0"
                        Template="{StaticResource CloseButtonTemplate}" />

                    <!-- Микро-анимация появления формы -->
                    <StackPanel
                        x:Name="LoginFormPanel"
                        VerticalAlignment="Center"
                        Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform />
                        </StackPanel.RenderTransform>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="12"
                                            To="0"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>

                        <TextBlock
                            Margin="0,0,0,30"
                            HorizontalAlignment="Center"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            Text="Login" />

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Username" />
                        <TextBox
                            x:Name="TBUserLogin"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="{StaticResource Light.BgInputBrush}"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            FontSize="15"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            KeyDown="TextBox_KeyDown"
                            Template="{StaticResource TextBoxBaseControlTemplate}" />

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Password" />
                        <!-- Контейнер поля пароля с кнопкой показа -->
                        <Border
                            Height="35"
                            Margin="0,5,0,25"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Light.BgInputBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource Light.BorderDefaultBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource Light.BorderFocusBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <PasswordBox
                                    x:Name="PBUserPassord"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="15"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="TBUserPassord_KeyDown"
                                    Template="{StaticResource InnerPasswordBox}" />
                                <TextBox
                                    x:Name="TBLoginPassShow"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="15"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="TBLoginPassShow_KeyDown"
                                    Template="{StaticResource InnerTextBox}"
                                    TextChanged="TBLoginPassShow_TextChanged"
                                    Visibility="Collapsed" />
                                <Button
                                    x:Name="LoginEyeBtn"
                                    Width="34"
                                    HorizontalAlignment="Right"
                                    Focusable="False"
                                    Click="LoginEyeBtn_Click"
                                    Template="{StaticResource EyeButtonTemplate}">
                                    <Viewbox Width="16" Height="16">
                                        <Path
                                            x:Name="LoginEyePath"
                                            Data="{StaticResource IconEye}"
                                            Fill="{StaticResource Light.TextMutedBrush}" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>

                        <Button
                            x:Name="LoginButton"
                            Height="40"
                            Margin="0,0,0,10"
                            Background="{StaticResource Light.AccentPrimaryBrush}"
                            Click="Button_Click"
                            Content="Login"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{StaticResource Light.TextInverseBrush}"
                            Template="{StaticResource PrimaryButtonTemplate}" />

                        <Button
                            x:Name="RegisterButton"
                            Height="35"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            Click="RegisterButton_Click"
                            Content="Register"
                            FontSize="14"
                            Foreground="{StaticResource Light.TextSecondaryBrush}"
                            Template="{StaticResource SecondaryButtonTemplate}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  Экран регистрации  -->
        <Grid
            x:Name="RegistrationGrid"
            Visibility="Collapsed">
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="RegCloseBtn"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="RegCloseBtn"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            <Border
                x:Name="RegistrationBorder"
                Padding="20"
                Background="{StaticResource Light.BgPrimaryBrush}"
                BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Button
                        x:Name="RegCloseBtn"
                        Width="28"
                        Height="28"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"
                        Content="✕"
                        FontSize="14"
                        Opacity="0"
                        Template="{StaticResource CloseButtonTemplate}" />

                    <StackPanel
                        x:Name="RegFormPanel"
                        VerticalAlignment="Center"
                        Opacity="0">
                        <StackPanel.RenderTransform>
                            <TranslateTransform />
                        </StackPanel.RenderTransform>

                        <TextBlock
                            Margin="0,0,0,30"
                            HorizontalAlignment="Center"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            Text="Registration" />

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Name" />
                        <TextBox
                            x:Name="TBUserName"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="{StaticResource Light.BgInputBrush}"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            FontSize="15"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            KeyDown="TextBox_KeyDown"
                            Template="{StaticResource TextBoxBaseControlTemplate}" />

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Username" />
                        <TextBox
                            x:Name="TBUserNameLogin"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="{StaticResource Light.BgInputBrush}"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            FontSize="15"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            KeyDown="TextBox_KeyDown"
                            Template="{StaticResource TextBoxBaseControlTemplate}" />

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Password" />
                        <Border
                            Height="35"
                            Margin="0,5,0,15"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Light.BgInputBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource Light.BorderDefaultBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource Light.BorderFocusBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <PasswordBox
                                    x:Name="PBUserPassword"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="PasswordBox_KeyDown"
                                    Template="{StaticResource InnerPasswordBox}" />
                                <TextBox
                                    x:Name="TBRegPassShow"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="TBRegPassShow_KeyDown"
                                    Template="{StaticResource InnerTextBox}"
                                    TextChanged="TBRegPassShow_TextChanged"
                                    Visibility="Collapsed" />
                                <Button
                                    x:Name="RegEyeBtn"
                                    Width="34"
                                    HorizontalAlignment="Right"
                                    Focusable="False"
                                    Click="RegEyeBtn_Click"
                                    Template="{StaticResource EyeButtonTemplate}">
                                    <Viewbox Width="16" Height="16">
                                        <Path
                                            x:Name="RegEyePath"
                                            Data="{StaticResource IconEye}"
                                            Fill="{StaticResource Light.TextMutedBrush}" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBlock Foreground="{StaticResource Light.TextSecondaryBrush}" Text="Confirm Password" />
                        <Border
                            Height="35"
                            Margin="0,5,0,25"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Light.BgInputBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource Light.BorderDefaultBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource Light.BorderFocusBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <PasswordBox
                                    x:Name="PBUserPasswordConfirm"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="PasswordBox_KeyDown"
                                    Template="{StaticResource InnerPasswordBox}" />
                                <TextBox
                                    x:Name="TBRegConfirmPassShow"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    KeyDown="TBRegConfirmPassShow_KeyDown"
                                    Template="{StaticResource InnerTextBox}"
                                    TextChanged="TBRegConfirmPassShow_TextChanged"
                                    Visibility="Collapsed" />
                                <Button
                                    x:Name="RegConfirmEyeBtn"
                                    Width="34"
                                    HorizontalAlignment="Right"
                                    Focusable="False"
                                    Click="RegConfirmEyeBtn_Click"
                                    Template="{StaticResource EyeButtonTemplate}">
                                    <Viewbox Width="16" Height="16">
                                        <Path
                                            x:Name="RegConfirmEyePath"
                                            Data="{StaticResource IconEye}"
                                            Fill="{StaticResource Light.TextMutedBrush}" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>

                        <Button
                            x:Name="DoRegisterButton"
                            Height="40"
                            Margin="0,0,0,10"
                            Background="{StaticResource Light.AccentPrimaryBrush}"
                            Click="DoRegisterButton_Click"
                            Content="Register"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{StaticResource Light.TextInverseBrush}"
                            Template="{StaticResource PrimaryButtonTemplate}" />

                        <Button
                            x:Name="BackButton"
                            Height="35"
                            BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            Click="BackButton_Click"
                            Content="Back to Login"
                            FontSize="14"
                            Foreground="{StaticResource Light.TextSecondaryBrush}"
                            Template="{StaticResource SecondaryButtonTemplate}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
