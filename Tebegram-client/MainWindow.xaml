<Window
    x:Class="Tebegrammmm.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Авторизация"
    Width="400"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    Opacity="1"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Grid>

        <!--  Основной Grid, не трогать!!!  -->


        <!--  Экран логина  -->
        <Grid
            x:Name="LoginGrid"
            Grid.RowSpan="2"
            Width="400"
            Height="400"
            Visibility="Visible">
            <Border
                Padding="20"
                Background="#FF1E1E1E"
                BorderBrush="#FF3C3C3C"
                BorderThickness="2"
                CornerRadius="20">
                <Grid>
                    <Button
                        Width="30"
                        Height="30"
                        Margin="0,-13,-13,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#FF3C3C3C"
                        BorderBrush="{x:Null}"
                        Click="CloseButton_Click"
                        Content="X"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White" />

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,30"
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="White"
                            Text="Login" />

                        <TextBlock Foreground="LightGray" Text="Username" />
                        <TextBox
                            x:Name="TBUserLogin"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="15"
                            Foreground="White"
                            KeyDown="TextBox_KeyDown" />

                        <TextBlock Foreground="LightGray" Text="Password" />
                        <PasswordBox
                            x:Name="PBUserPassord"
                            Height="35"
                            Margin="0,5,0,25"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="14"
                            Foreground="White"
                            KeyDown="TBUserPassord_KeyDown" />

                        <Button
                            x:Name="LoginButton"
                            Height="40"
                            Margin="0,0,0,10"
                            Background="#FF007ACC"
                            Click="Button_Click"
                            Content="Login"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White" />

                        <Button
                            x:Name="RegisterButton"
                            Height="35"
                            Background="Transparent"
                            BorderBrush="#FF3C3C3C"
                            Click="RegisterButton_Click"
                            Content="Register"
                            FontSize="14"
                            Foreground="LightGray" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  Экран регистрации  -->
        <Grid
            x:Name="RegistrationGrid"
            Grid.RowSpan="2"
            Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="416*" />
                <RowDefinition Height="13*" />
                <RowDefinition Height="9*" />
                <RowDefinition Height="0*" />
            </Grid.RowDefinitions>
            <Border
                x:Name="RegistrationBorder"
                Grid.RowSpan="4"
                Height="500"
                Padding="20"
                VerticalAlignment="Top"
                Background="#FF1E1E1E"
                BorderBrush="#FF3C3C3C"
                BorderThickness="2"
                CornerRadius="20">
                <Grid>
                    <Button
                        Width="30"
                        Height="30"
                        Margin="0,-13,-13,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#FF3C3C3C"
                        BorderBrush="{x:Null}"
                        Click="CloseButton_Click"
                        Content="X"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White" />

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,30"
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="White"
                            Text="Registration" />

                        <TextBlock Foreground="LightGray" Text="Name" />
                        <TextBox
                            x:Name="TBUserName"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="15"
                            Foreground="White"
                            KeyDown="TextBox_KeyDown" />

                        <TextBlock Foreground="LightGray" Text="Username" />
                        <TextBox
                            x:Name="TBUserNameLogin"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="15"
                            Foreground="White"
                            KeyDown="TextBox_KeyDown" />

                        <TextBlock Foreground="LightGray" Text="Password" />
                        <PasswordBox
                            x:Name="PBUserPassword"
                            Height="35"
                            Margin="0,5,0,15"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="14"
                            Foreground="White"
                            KeyDown="PasswordBox_KeyDown" />

                        <TextBlock Foreground="LightGray" Text="Confirm Password" />
                        <PasswordBox
                            x:Name="PBUserPasswordConfirm"
                            Height="35"
                            Margin="0,5,0,25"
                            Background="#FF2D2D30"
                            BorderBrush="#FF3C3C3C"
                            FontSize="14"
                            Foreground="White"
                            KeyDown="PasswordBox_KeyDown" />

                        <Button
                            x:Name="DoRegisterButton"
                            Height="40"
                            Margin="0,0,0,10"
                            Background="#FF007ACC"
                            Click="DoRegisterButton_Click"
                            Content="Register"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White" />

                        <Button
                            x:Name="BackButton"
                            Height="35"
                            Background="Transparent"
                            BorderBrush="#FF3C3C3C"
                            Click="BackButton_Click"
                            Content="Back to Login"
                            FontSize="14"
                            Foreground="LightGray" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
