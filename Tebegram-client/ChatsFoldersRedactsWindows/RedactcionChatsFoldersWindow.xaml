<Window
    x:Class="Tebegrammmm.ChatsFoldersRedactsWindows.RedactcionChatsFoldersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Папки"
    Width="380"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>

        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{DynamicResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="MinimizeButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{DynamicResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="{DynamicResource Light.TextPrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PrimaryButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.AccentPressedBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SecondaryButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Background="Transparent"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!--  Круглая кнопка удаления  -->
        <ControlTemplate x:Key="IconButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Background="Transparent"
                CornerRadius="999">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerMutedBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </Window.Resources>

    <Grid Background="Transparent">
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Border
                Padding="24"
                Background="{DynamicResource Light.BgPrimaryBrush}"
                BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <StackPanel
                        x:Name="WindowControls"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Opacity="0"
                        Orientation="Horizontal">
                        <Button
                            Width="28"
                            Height="28"
                            Click="MinimizeBtn_Click"
                            Content="─"
                            FontSize="14"
                            Template="{StaticResource MinimizeButtonTemplate}" />
                        <Button
                            Width="28"
                            Height="28"
                            Margin="2,0,0,0"
                            Click="CloseBtn_Click"
                            Content="✕"
                            FontSize="14"
                            Template="{StaticResource CloseButtonTemplate}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="FormPanel"
                        Opacity="0"
                        d:Opacity="1">
                        <StackPanel.RenderTransform>
                            <TranslateTransform />
                        </StackPanel.RenderTransform>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="12"
                                            To="0"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>

                        <!--  Заголовок  -->
                        <TextBlock
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Light.TextPrimaryBrush}"
                            Text="Мои папки" />

                        <!--  Список папок  -->
                        <Border
                            Margin="0,0,0,12"
                            Background="{DynamicResource Light.BgSurfaceBrush}"
                            BorderBrush="{DynamicResource Light.BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <ListBox
                                x:Name="LBChatsFolders"
                                MaxHeight="300"
                                Background="Transparent"
                                BorderThickness="0"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                SelectionChanged="LBChatsFolders_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Padding" Value="12,8" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Light.AccentMutedBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!--  Иконка папки  -->
                                            <Border
                                                Width="32"
                                                Height="32"
                                                Background="{DynamicResource Light.AccentMutedBrush}"
                                                CornerRadius="10">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="{StaticResource IconChat}" Fill="{DynamicResource Light.AccentTextBrush}" />
                                                </Viewbox>
                                            </Border>

                                            <!--  Название + счётчик  -->
                                            <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource Light.TextPrimaryBrush}"
                                                    Text="{Binding FolderName}" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{DynamicResource Light.TextMutedBrush}"
                                                    Text="{Binding ChatsCount, StringFormat='Чатов: {0}'}" />
                                            </StackPanel>

                                            <!--  Кнопка удаления (только для редактируемых)  -->
                                            <Button
                                                Grid.Column="2"
                                                Width="28"
                                                Height="28"
                                                Click="Delete_Folder_Click"
                                                Template="{StaticResource IconButtonTemplate}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCanRedact}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Viewbox Width="13" Height="13">
                                                    <Path
                                                        Data="{StaticResource IconClose}"
                                                        Fill="{DynamicResource Light.DangerBrush}"
                                                        Stretch="Uniform" />
                                                </Viewbox>
                                            </Button>

                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!--  Добавить папку  -->
                        <Button
                            Height="40"
                            Margin="0,0,0,12"
                            Background="{DynamicResource Light.AccentPrimaryBrush}"
                            Click="Button_Click"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Template="{StaticResource PrimaryButtonTemplate}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    FontSize="18"
                                    Text="+" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Добавить папку" />
                            </StackPanel>
                        </Button>

                        <!--  Закрыть  -->
                        <Button
                            Height="38"
                            BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            Click="Button_Click_1"
                            Content="Закрыть"
                            FontSize="14"
                            Foreground="{DynamicResource Light.TextSecondaryBrush}"
                            Template="{StaticResource SecondaryButtonTemplate}" />

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
