<Window
    x:Class="Tebegrammmm.VoiceRoom"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Звонок"
    Width="360"
    Height="440"
    AllowsTransparency="True"
    Background="Transparent"
    Closing="Window_Closing"
    MouseDown="Window_MouseDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>

        <!-- Кнопка закрытия: прозрачная → красная при наведении -->
        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Круглая кнопка управления звонком -->
        <ControlTemplate x:Key="CircleActionButton" TargetType="Button">
            <Border
                x:Name="Bd"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Background="{TemplateBinding Background}"
                CornerRadius="999">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.62" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="MinimizeButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgElevatedBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource Light.TextPrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </Window.Resources>

    <Grid Background="Transparent">
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Border
                Padding="24"
                Background="{StaticResource Light.BgPrimaryBrush}"
                BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <!--  Кнопки управления окном  -->
                    <StackPanel
                        x:Name="WindowControls"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Opacity="0"
                        Orientation="Horizontal">
                        <Button
                            Width="28"
                            Height="28"
                            Click="MinimizeBtn_Click"
                            Content="─"
                            FontSize="14"
                            Template="{StaticResource MinimizeButtonTemplate}" />
                        <Button
                            x:Name="CloseBtn"
                            Width="28"
                            Height="28"
                            Margin="2,0,0,0"
                            Click="CloseBtn_Click"
                            Content="✕"
                            FontSize="14"
                            Template="{StaticResource CloseButtonTemplate}" />
                    </StackPanel>

                    <!--  Обёртка с entrance-анимацией  -->
                    <Grid x:Name="ContentGrid" Opacity="0" d:Opacity="1">
                        <Grid.RenderTransform>
                            <TranslateTransform />
                        </Grid.RenderTransform>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="12"
                                            To="0"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>

                        <!--  Входящий звонок  -->
                        <Grid Name="DefoultVoiceRoom" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="96" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Light.TextPrimaryBrush}"
                                Text="{Binding Name}" />

                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Grid Width="170" Height="170">
                                    <Ellipse Fill="{StaticResource Light.BgDeepBrush}" />
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Avatar}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                                <TextBlock
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource Light.TextMutedBrush}"
                                    Text="Входящий звонок…" />
                            </StackPanel>

                            <StackPanel
                                x:Name="DefaultButtonsPanel"
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="DefaultButtonsPanelTransform" />
                                </StackPanel.RenderTransform>

                                <!--  Отклонить  -->
                                <Button
                                    Width="56"
                                    Height="56"
                                    Margin="14,0"
                                    Background="{StaticResource Light.DangerBrush}"
                                    Click="Button_Click_Decline"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Отклонить">
                                    <Viewbox Width="22" Height="22">
                                        <Path
                                            Data="{StaticResource IconClose}"
                                            Fill="White"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>

                                <!--  Принять  -->
                                <Button
                                    Width="56"
                                    Height="56"
                                    Margin="14,0"
                                    Background="{StaticResource Light.AccentPrimaryBrush}"
                                    Click="Button_Click_Accept"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Принять">
                                    <Viewbox Width="22" Height="22">
                                        <Path
                                            Data="{StaticResource IconPhone}"
                                            Fill="White"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  Активный звонок  -->
                        <Grid Name="ActiveVoiceRoom" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="96" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Light.TextPrimaryBrush}"
                                Text="{Binding Name}" />

                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Grid Width="170" Height="170">
                                    <Ellipse Fill="{StaticResource Light.BgDeepBrush}" />
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Avatar}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!--  Бейдж микрофона  -->
                                    <Border
                                        Width="44"
                                        Height="44"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Background="{StaticResource Light.BgPrimaryBrush}"
                                        CornerRadius="22">
                                        <Border
                                            x:Name="MicButtonBorder"
                                            Width="36"
                                            Height="36"
                                            Background="{StaticResource Light.BgElevatedBrush}"
                                            CornerRadius="18">
                                            <Viewbox Width="16" Height="16">
                                                <Path
                                                    x:Name="MicAvatarPath"
                                                    Data="{StaticResource IconMic}"
                                                    Fill="{StaticResource Light.TextPrimaryBrush}"
                                                    Stretch="Uniform" />
                                            </Viewbox>
                                        </Border>
                                    </Border>
                                </Grid>

                                <TextBlock
                                    x:Name="CallTimeText"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{StaticResource Light.TextMutedBrush}"
                                    Text="00:00" />
                            </StackPanel>

                            <!--  Кнопки управления  -->
                            <StackPanel
                                x:Name="ActiveButtonsPanel"
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="ButtonsPanelTransform" />
                                </StackPanel.RenderTransform>

                                <!--  Демонстрация экрана  -->
                                <Button
                                    x:Name="BtnScreenShare"
                                    Width="48"
                                    Height="48"
                                    Margin="5,0"
                                    Background="{StaticResource Light.BgElevatedBrush}"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Демонстрация экрана">
                                    <Viewbox Width="20" Height="20">
                                        <Path
                                            Data="{StaticResource IconScreenShare}"
                                            Fill="{StaticResource Light.TextPrimaryBrush}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>

                                <!--  Камера  -->
                                <Button
                                    x:Name="BtnCamera"
                                    Width="48"
                                    Height="48"
                                    Margin="5,0"
                                    Background="{StaticResource Light.BgElevatedBrush}"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Включить видеозвонок">
                                    <Viewbox Width="20" Height="20">
                                        <Path
                                            Data="{StaticResource IconCamera}"
                                            Fill="{StaticResource Light.TextPrimaryBrush}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>

                                <!--  Завершить  -->
                                <Button
                                    x:Name="BtnHangup"
                                    Width="56"
                                    Height="56"
                                    Margin="5,0"
                                    Background="{StaticResource Light.DangerBrush}"
                                    Click="Button_Click"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Завершить">
                                    <Viewbox Width="22" Height="22">
                                        <Path
                                            Data="{StaticResource IconPhone}"
                                            Fill="White"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>

                                <!--  Микрофон  -->
                                <Button
                                    x:Name="BtnMic"
                                    Width="48"
                                    Height="48"
                                    Margin="5,0"
                                    Background="{StaticResource Light.BgElevatedBrush}"
                                    Click="Button_Click_OffOnMicrofon"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Микрофон">
                                    <Viewbox Width="20" Height="20">
                                        <Path
                                            x:Name="MicIconPath"
                                            Data="{StaticResource IconMic}"
                                            Fill="{StaticResource Light.TextPrimaryBrush}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>

                                <!--  Добавить участника  -->
                                <Button
                                    x:Name="BtnAddUser"
                                    Width="48"
                                    Height="48"
                                    Margin="5,0"
                                    Background="{StaticResource Light.BgElevatedBrush}"
                                    Template="{StaticResource CircleActionButton}"
                                    ToolTip="Добавить участника">
                                    <Viewbox Width="20" Height="20">
                                        <Path
                                            Data="{StaticResource IconPlus}"
                                            Fill="{StaticResource Light.TextPrimaryBrush}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
