<Window
    x:Class="Tebegrammmm.SettingsPanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local1="clr-namespace:Tebegrammmm.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Настройки"
    Width="400"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>

        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="MinimizeButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgElevatedBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource Light.TextPrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!--  Кнопка выхода: outline красная  -->
        <ControlTemplate x:Key="DangerButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Background="Transparent"
                BorderBrush="{StaticResource Light.DangerBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerMutedBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Light.DangerBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </Window.Resources>

    <Grid Background="Transparent">
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Border
                Padding="24"
                Background="{StaticResource Light.BgPrimaryBrush}"
                BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <StackPanel
                        x:Name="WindowControls"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Opacity="0"
                        Orientation="Horizontal">
                        <Button
                            Width="28"
                            Height="28"
                            Click="MinimizeBtn_Click"
                            Content="─"
                            FontSize="14"
                            Template="{StaticResource MinimizeButtonTemplate}" />
                        <Button
                            Width="28"
                            Height="28"
                            Margin="2,0,0,0"
                            Click="CloseBtn_Click"
                            Content="✕"
                            FontSize="14"
                            Template="{StaticResource CloseButtonTemplate}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="FormPanel"
                        Opacity="0"
                        d:Opacity="1">
                        <StackPanel.RenderTransform>
                            <TranslateTransform />
                        </StackPanel.RenderTransform>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="12"
                                            To="0"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>

                        <!--  Заголовок  -->
                        <TextBlock
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                            Text="Настройки" />

                        <!--  Блок пользователя  -->
                        <StackPanel
                            x:Name="UserInfo"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                            <!--  Аватар  -->
                            <local1:UserControl1
                                Width="80"
                                Height="80"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Center"
                                Avatar="{Binding Avatar}" />

                            <!--  Имя пользователя  -->
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Light.TextPrimaryBrush}"
                                Text="{Binding Name}" />
                        </StackPanel>

                        <!--  Разделитель  -->
                        <Border
                            Margin="0,0,0,20"
                            Background="{StaticResource Light.BorderSubtleBrush}"
                            Height="1" />

                        <!--  Информационные строки  -->
                        <Border
                            Margin="0,0,0,20"
                            Background="{StaticResource Light.BgSurfaceBrush}"
                            BorderBrush="{StaticResource Light.BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel>

                                <!--  Логин  -->
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource Light.TextMutedBrush}"
                                            Text="ЛОГИН" />
                                        <TextBlock
                                            x:Name="TBLogin"
                                            FontSize="15"
                                            Foreground="{StaticResource Light.TextPrimaryBrush}"
                                            Text="{Binding Login}" />
                                    </StackPanel>
                                    <Viewbox
                                        Grid.Column="1"
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center">
                                        <Path
                                            Data="{StaticResource IconInfo}"
                                            Fill="{StaticResource Light.TextMutedBrush}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Grid>

                                <!--  Разделитель строк  -->
                                <Border
                                    Margin="16,0"
                                    Background="{StaticResource Light.BorderSubtleBrush}"
                                    Height="1" />

                                <!--  Имя пользователя  -->
                                <Grid Margin="16,14">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource Light.TextMutedBrush}"
                                            Text="ИМЯ ПОЛЬЗОВАТЕЛЯ" />
                                        <TextBlock
                                            x:Name="TBUsername"
                                            FontSize="15"
                                            Foreground="{StaticResource Light.TextPrimaryBrush}" />
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!--  Устройство ввода  -->
                        <Border
                            Margin="0,0,0,20"
                            Background="{StaticResource Light.BgSurfaceBrush}"
                            BorderBrush="{StaticResource Light.BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource Light.TextMutedBrush}"
                                    Text="УСТРОЙСТВО ВВОДА" />
                                <ComboBox
                                    x:Name="InputDeviceCB"
                                    Grid.Row="1"
                                    Background="{StaticResource Light.BgInputBrush}"
                                    BorderBrush="{StaticResource Light.BorderDefaultBrush}"
                                    BorderThickness="1"
                                    FontSize="13"
                                    Foreground="{StaticResource Light.TextPrimaryBrush}"
                                    SelectionChanged="InputDeviceCB_SelectionChanged" />
                            </Grid>
                        </Border>

                        <!--  Кнопка выйти  -->
                        <Button
                            Height="40"
                            Click="Button_Exit_Click"
                            Template="{StaticResource DangerButtonTemplate}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontSize="16"
                                    Foreground="{StaticResource Light.DangerBrush}"
                                    Text="⏻" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource Light.DangerBrush}"
                                    Text="Выйти из аккаунта" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
