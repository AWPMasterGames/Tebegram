<Application
    x:Class="Tebegrammmm.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Tebegrammmm"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!--  Единый шрифт приложения: Segoe UI Variable (Win11), Segoe UI (Win10)  -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            </Style>
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resourses/ColorSystem.xaml" />
                <ResourceDictionary Source="/Resourses/MessengerTheme_Base.xaml" />
                <ResourceDictionary Source="/Resourses/SearchTextBox.xaml" />
                <ResourceDictionary Source="/Resourses/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
