<Window
    x:Class="Tebegrammmm.AddContact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tebegrammmm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Контакт"
    Width="400"
    Height="350"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="TBTitle"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="25"
            Text="Добавить контакт" />
        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="10,0"
                VerticalAlignment="Bottom"
                Foreground="Gray"
                Text="Имя" />
            <TextBox
                x:Name="TBName"
                Grid.Row="1"
                FontSize="20"
                Text="" />
        </Grid>
        <Grid
            Grid.Row="2"
            Grid.Column="1"
            Margin="0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="10,0"
                VerticalAlignment="Bottom"
                Foreground="Gray"
                Text="Username" />
            <TextBox
                x:Name="TBUsername"
                Grid.Row="1"
                FontSize="20"
                KeyDown="TBUsername_KeyDown"
                Text="" />
        </Grid>
        <StackPanel
            Grid.Row="4"
            Grid.Column="1"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="25"
                Margin="10"
                Click="Button_Click_1"
                Content="Добавить" />
            <Button
                Width="75"
                Height="25"
                Margin="10"
                Click="Button_Click"
                Content="Отмена" />
        </StackPanel>
    </Grid>
</Window>
