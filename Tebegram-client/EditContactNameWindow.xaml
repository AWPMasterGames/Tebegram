<Window
    x:Class="Tebegrammmm.EditContactNameWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Изменить имя контакта"
    Width="380"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>

        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{DynamicResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.DangerHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="MinimizeButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                <TextBlock
                    x:Name="Txt"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{DynamicResource Light.TextMutedBrush}"
                    Text="{TemplateBinding Content}" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                    <Setter TargetName="Txt" Property="Foreground" Value="{DynamicResource Light.TextPrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PrimaryButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.AccentPressedBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SecondaryButtonTemplate" TargetType="Button">
            <Border
                x:Name="Bd"
                Background="Transparent"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgElevatedBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Light.BgDeepBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </Window.Resources>

    <Grid Background="Transparent">
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="UIElement.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="WindowControls"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.25" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Border
                Padding="20"
                Background="{DynamicResource Light.BgPrimaryBrush}"
                BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="20"
                        Opacity="0.12"
                        ShadowDepth="4"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <StackPanel
                        x:Name="WindowControls"
                        Margin="0,4,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Opacity="0"
                        Orientation="Horizontal">
                        <Button
                            Width="28"
                            Height="28"
                            Click="MinimizeBtn_Click"
                            Content="─"
                            FontSize="14"
                            Template="{StaticResource MinimizeButtonTemplate}" />
                        <Button
                            x:Name="CloseBtn"
                            Width="28"
                            Height="28"
                            Margin="2,0,0,0"
                            Click="Button_Cancel_Click"
                            Content="✕"
                            FontSize="14"
                            Template="{StaticResource CloseButtonTemplate}" />
                    </StackPanel>

                    <StackPanel
                        x:Name="FormPanel"
                        VerticalAlignment="Center"
                        Opacity="0"
                        d:Opacity="1">
                        <StackPanel.RenderTransform>
                            <TranslateTransform />
                        </StackPanel.RenderTransform>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="12"
                                            To="0"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>

                        <TextBlock
                            Margin="0,0,0,30"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Light.TextPrimaryBrush}"
                            Text="Изменить имя" />

                        <TextBlock
                            Foreground="{DynamicResource Light.TextSecondaryBrush}"
                            Text="Новое имя контакта" />
                        <TextBox
                            x:Name="TBName"
                            Height="35"
                            Margin="0,5,0,25"
                            Background="{DynamicResource Light.BgInputBrush}"
                            BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                            FontSize="15"
                            Foreground="{DynamicResource Light.TextPrimaryBrush}"
                            KeyDown="TBName_KeyDown"
                            Template="{StaticResource TextBoxBaseControlTemplate}" />

                        <Button
                            Height="40"
                            Margin="0,0,0,10"
                            Background="{DynamicResource Light.AccentPrimaryBrush}"
                            Click="Button_Save_Click"
                            Content="Сохранить"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Light.TextInverseBrush}"
                            IsDefault="True"
                            Template="{StaticResource PrimaryButtonTemplate}" />

                        <Button
                            Height="35"
                            BorderBrush="{DynamicResource Light.BorderDefaultBrush}"
                            BorderThickness="1"
                            Click="Button_Cancel_Click"
                            Content="Отмена"
                            FontSize="14"
                            Foreground="{DynamicResource Light.TextSecondaryBrush}"
                            IsCancel="True"
                            Template="{StaticResource SecondaryButtonTemplate}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
