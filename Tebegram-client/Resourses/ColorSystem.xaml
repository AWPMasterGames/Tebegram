<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════
        ФОНЫ (от тёмного к светлому)
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorBgDeep">#0D1117</Color>
    <Color x:Key="ColorBgPrimary">#161B27</Color>
    <Color x:Key="ColorBgSurface">#1E2438</Color>
    <Color x:Key="ColorBgElevated">#262D47</Color>
    <Color x:Key="ColorBgInput">#1A1F33</Color>
    <Color x:Key="ColorBgOverlay">#0D1117CC</Color>

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource ColorBgDeep}" />
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource ColorBgPrimary}" />
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource ColorBgSurface}" />
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource ColorBgElevated}" />
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource ColorBgInput}" />

    <!--
        ══════════════════════════════════════════════
        АКЦЕНТНЫЙ ЦВЕТ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorAccentPrimary">#5B6BF5</Color>
    <Color x:Key="ColorAccentHover">#6B7BFF</Color>
    <Color x:Key="ColorAccentPressed">#4A5AE0</Color>
    <Color x:Key="ColorAccentMuted">#1E2560</Color>
    <Color x:Key="ColorAccentText">#8B9BFF</Color>

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource ColorAccentPrimary}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource ColorAccentHover}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource ColorAccentPressed}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource ColorAccentMuted}" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource ColorAccentText}" />

    <!--
        ══════════════════════════════════════════════
        СЕМАНТИЧЕСКИЕ ЦВЕТА
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorDanger">#F04F4F</Color>
    <Color x:Key="ColorDangerHover">#FF6060</Color>
    <Color x:Key="ColorDangerMuted">#3A1515</Color>

    <Color x:Key="ColorSuccess">#3ECF8E</Color>
    <Color x:Key="ColorSuccessMuted">#0F3326</Color>

    <Color x:Key="ColorWarning">#F5A623</Color>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource ColorDangerHover}" />
    <SolidColorBrush x:Key="DangerMutedBrush" Color="{StaticResource ColorDangerMuted}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />

    <!--
        ══════════════════════════════════════════════
        ТЕКСТ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorTextPrimary">#E8EAED</Color>
    <Color x:Key="ColorTextSecondary">#8B91A8</Color>
    <Color x:Key="ColorTextMuted">#4A5068</Color>
    <Color x:Key="ColorTextDisabled">#363B52</Color>
    <Color x:Key="ColorTextInverse">#0D1117</Color>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource ColorTextDisabled}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource ColorTextInverse}" />

    <!--
        ══════════════════════════════════════════════
        ГРАНИЦЫ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorBorderSubtle">#1E2438</Color>
    <Color x:Key="ColorBorderDefault">#2E3550</Color>
    <Color x:Key="ColorBorderStrong">#3E4868</Color>
    <Color x:Key="ColorBorderFocus">#5B6BF5</Color>

    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource ColorBorderSubtle}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource ColorBorderDefault}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource ColorBorderStrong}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource ColorBorderFocus}" />

    <!--
        ══════════════════════════════════════════════
        СООБЩЕНИЯ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="ColorMsgOutgoing">#2D3F9E</Color>
    <Color x:Key="ColorMsgIncoming">#262D47</Color>
    <Color x:Key="ColorMsgFailed">#3A1515</Color>
    <Color x:Key="ColorMsgPending">#1E2438</Color>

    <SolidColorBrush x:Key="MsgOutgoingBrush" Color="{StaticResource ColorMsgOutgoing}" />
    <SolidColorBrush x:Key="MsgIncomingBrush" Color="{StaticResource ColorMsgIncoming}" />
    <SolidColorBrush x:Key="MsgFailedBrush" Color="{StaticResource ColorMsgFailed}" />
    <SolidColorBrush x:Key="MsgPendingBrush" Color="{StaticResource ColorMsgPending}" />

    <!--
        ══════════════════════════════════════════════
        СПЕЦИАЛЬНЫЕ ГРАДИЕНТЫ
        ══════════════════════════════════════════════
    -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="#5B6BF5" />
        <GradientStop Offset="1.0" Color="#7B4FE0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#161B27" />
        <GradientStop Offset="1.0" Color="#0D1117" />
    </LinearGradientBrush>

    <!--
        ══════════════════════════════════════════════
        ПРОЗРАЧНОСТЬ (для hover/overlay эффектов)
        ══════════════════════════════════════════════
    -->
    <SolidColorBrush
        x:Key="HoverOverlayBrush"
        Opacity="0.05"
        Color="#FFFFFF" />
    <SolidColorBrush
        x:Key="PressedOverlayBrush"
        Opacity="0.1"
        Color="#000000" />
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — ФОНЫ
        Белые и светло-серые поверхности с чуть-чуть
        голубоватым оттенком (как Telegram Light / iOS)
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorBgDeep">#E8ECF5</Color>
    <Color x:Key="Light.ColorBgPrimary">#FFFFFF</Color>
    <Color x:Key="Light.ColorBgSurface">#F2F4FA</Color>
    <Color x:Key="Light.ColorBgElevated">#EAECF5</Color>
    <Color x:Key="Light.ColorBgInput">#F0F2F8</Color>

    <SolidColorBrush x:Key="Light.BgDeepBrush" Color="{StaticResource Light.ColorBgDeep}" />
    <SolidColorBrush x:Key="Light.BgPrimaryBrush" Color="{StaticResource Light.ColorBgPrimary}" />
    <SolidColorBrush x:Key="Light.BgSurfaceBrush" Color="{StaticResource Light.ColorBgSurface}" />
    <SolidColorBrush x:Key="Light.BgElevatedBrush" Color="{StaticResource Light.ColorBgElevated}" />
    <SolidColorBrush x:Key="Light.BgInputBrush" Color="{StaticResource Light.ColorBgInput}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — АКЦЕНТ
        Тот же синий, но чуть насыщеннее — на белом
        фоне #5B6BF5 воспринимается ярче, чем на тёмном
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorAccentPrimary">#4A5AE8</Color>
    <Color x:Key="Light.ColorAccentHover">#5B6BF5</Color>
    <Color x:Key="Light.ColorAccentPressed">#3A4AD0</Color>
    <Color x:Key="Light.ColorAccentMuted">#DCE0FF</Color>
    <Color x:Key="Light.ColorAccentText">#3A4AD0</Color>

    <SolidColorBrush x:Key="Light.AccentPrimaryBrush" Color="{StaticResource Light.ColorAccentPrimary}" />
    <SolidColorBrush x:Key="Light.AccentHoverBrush" Color="{StaticResource Light.ColorAccentHover}" />
    <SolidColorBrush x:Key="Light.AccentPressedBrush" Color="{StaticResource Light.ColorAccentPressed}" />
    <SolidColorBrush x:Key="Light.AccentMutedBrush" Color="{StaticResource Light.ColorAccentMuted}" />
    <SolidColorBrush x:Key="Light.AccentTextBrush" Color="{StaticResource Light.ColorAccentText}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — СЕМАНТИЧЕСКИЕ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorDanger">#D93025</Color>
    <Color x:Key="Light.ColorDangerHover">#E84030</Color>
    <Color x:Key="Light.ColorDangerMuted">#FDECEA</Color>

    <Color x:Key="Light.ColorSuccess">#1E8A5E</Color>
    <Color x:Key="Light.ColorSuccessMuted">#E6F6F0</Color>

    <Color x:Key="Light.ColorWarning">#C97A00</Color>

    <SolidColorBrush x:Key="Light.DangerBrush" Color="{StaticResource Light.ColorDanger}" />
    <SolidColorBrush x:Key="Light.DangerHoverBrush" Color="{StaticResource Light.ColorDangerHover}" />
    <SolidColorBrush x:Key="Light.DangerMutedBrush" Color="{StaticResource Light.ColorDangerMuted}" />
    <SolidColorBrush x:Key="Light.SuccessBrush" Color="{StaticResource Light.ColorSuccess}" />
    <SolidColorBrush x:Key="Light.WarningBrush" Color="{StaticResource Light.ColorWarning}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — ТЕКСТ
        Почти чёрный текст на белом — стандарт для
        читаемости. Мутный — тёплый серый, не холодный.
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorTextPrimary">#0D1117</Color>
    <Color x:Key="Light.ColorTextSecondary">#505870</Color>
    <Color x:Key="Light.ColorTextMuted">#909AAF</Color>
    <Color x:Key="Light.ColorTextDisabled">#C4C8D8</Color>
    <Color x:Key="Light.ColorTextInverse">#FFFFFF</Color>

    <SolidColorBrush x:Key="Light.TextPrimaryBrush" Color="{StaticResource Light.ColorTextPrimary}" />
    <SolidColorBrush x:Key="Light.TextSecondaryBrush" Color="{StaticResource Light.ColorTextSecondary}" />
    <SolidColorBrush x:Key="Light.TextMutedBrush" Color="{StaticResource Light.ColorTextMuted}" />
    <SolidColorBrush x:Key="Light.TextDisabledBrush" Color="{StaticResource Light.ColorTextDisabled}" />
    <SolidColorBrush x:Key="Light.TextInverseBrush" Color="{StaticResource Light.ColorTextInverse}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — ГРАНИЦЫ
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorBorderSubtle">#EAECF5</Color>
    <Color x:Key="Light.ColorBorderDefault">#D4D8E8</Color>
    <Color x:Key="Light.ColorBorderStrong">#B0B8D0</Color>
    <Color x:Key="Light.ColorBorderFocus">#4A5AE8</Color>

    <SolidColorBrush x:Key="Light.BorderSubtleBrush" Color="{StaticResource Light.ColorBorderSubtle}" />
    <SolidColorBrush x:Key="Light.BorderDefaultBrush" Color="{StaticResource Light.ColorBorderDefault}" />
    <SolidColorBrush x:Key="Light.BorderStrongBrush" Color="{StaticResource Light.ColorBorderStrong}" />
    <SolidColorBrush x:Key="Light.BorderFocusBrush" Color="{StaticResource Light.ColorBorderFocus}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — СООБЩЕНИЯ
        Исходящие — акцентный синий с белым текстом.
        Входящие — белая карточка с лёгкой тенью.
        ══════════════════════════════════════════════
    -->
    <Color x:Key="Light.ColorMsgOutgoing">#4A5AE8</Color>
    <Color x:Key="Light.ColorMsgIncoming">#FFFFFF</Color>
    <Color x:Key="Light.ColorMsgFailed">#FDECEA</Color>
    <Color x:Key="Light.ColorMsgPending">#EEF0FA</Color>

    <SolidColorBrush x:Key="Light.MsgOutgoingBrush" Color="{StaticResource Light.ColorMsgOutgoing}" />
    <SolidColorBrush x:Key="Light.MsgIncomingBrush" Color="{StaticResource Light.ColorMsgIncoming}" />
    <SolidColorBrush x:Key="Light.MsgFailedBrush" Color="{StaticResource Light.ColorMsgFailed}" />
    <SolidColorBrush x:Key="Light.MsgPendingBrush" Color="{StaticResource Light.ColorMsgPending}" />

    <!--
        ══════════════════════════════════════════════
        СВЕТЛАЯ ТЕМА — ПРОЗРАЧНОСТЬ
        ══════════════════════════════════════════════
    -->
    <SolidColorBrush
        x:Key="Light.HoverOverlayBrush"
        Opacity="0.04"
        Color="#000000" />
    <SolidColorBrush
        x:Key="Light.PressedOverlayBrush"
        Opacity="0.08"
        Color="#000000" />

</ResourceDictionary>
