<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!--
      Харвест всех файлов из папки Release-сборки клиента.
      Исключаем отладочные (.pdb) и runtime-артефакты (CrashLogs, Data, user.data).
      Перед сборкой инсталлятора клиент должен быть собран в Release.
    -->
    <ComponentGroup Id="MainAppFiles" Directory="INSTALLFOLDER">
      <Files Include="..\Tebegram-client\bin\$(Configuration)\net8.0-windows\*.exe" />
      <Files Include="..\Tebegram-client\bin\$(Configuration)\net8.0-windows\*.dll" />
      <Files Include="..\Tebegram-client\bin\$(Configuration)\net8.0-windows\*.json" />
      <Files Include="..\Tebegram-client\bin\$(Configuration)\net8.0-windows\*.config" />
    </ComponentGroup>
  </Fragment>
</Wix>
