<Window x:Class="Tebegrammmm.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registration"
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FF2D2D30"
        AllowsTransparency="True"
        WindowStyle="None"
        Opacity="1"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="20" Background="#FF1E1E1E" BorderBrush="#FF3C3C3C" BorderThickness="2" Padding="20">
        <Grid>
            <Button Content="X"
                    Width="30" Height="30"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-13,-13,0"
                    Background="#FF3C3C3C"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontWeight="Bold"
                    FontSize="14"
                    Click="CloseButton_Click"/>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Registration"
                           FontSize="28"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 30" />

                <TextBlock Text="Name" Foreground="LightGray"/>
                <TextBox x:Name="TBUserName"
                         Height="35"
                         Margin="0 5 0 15"
                         FontSize="15"
                         Background="#FF2D2D30"
                         Foreground="White"
                         BorderBrush="#FF3C3C3C"
                         KeyDown="TextBox_KeyDown"/>

                <TextBlock Text="Username" Foreground="LightGray"/>
                <TextBox x:Name="TBUserLogin"
                         Height="35"
                         Margin="0 5 0 15"
                         FontSize="15"
                         Background="#FF2D2D30"
                         Foreground="White"
                         BorderBrush="#FF3C3C3C"
                         KeyDown="TextBox_KeyDown"/>

                <TextBlock Text="Password" Foreground="LightGray"/>
                <PasswordBox x:Name="PBUserPassword"
                             Height="35"
                             Margin="0 5 0 15"
                             FontSize="14"
                             Background="#FF2D2D30"
                             Foreground="White"
                             BorderBrush="#FF3C3C3C"
                             KeyDown="PasswordBox_KeyDown"/>

                <TextBlock Text="Confirm Password" Foreground="LightGray"/>
                <PasswordBox x:Name="PBUserPasswordConfirm"
                             Height="35"
                             Margin="0 5 0 25"
                             FontSize="14"
                             Background="#FF2D2D30"
                             Foreground="White"
                             BorderBrush="#FF3C3C3C"
                             KeyDown="PasswordBox_KeyDown"/>

                <Button x:Name="RegisterButton" Content="Register"
                        Height="40"
                        Background="#FF007ACC"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Margin="0 0 0 10"
                        Click="RegisterButton_Click"/>

                <Button x:Name="BackButton" Content="Back to Login"
                        Height="35"
                        Background="Transparent"
                        Foreground="LightGray"
                        FontSize="14"
                        BorderBrush="#FF3C3C3C"
                        Click="BackButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
