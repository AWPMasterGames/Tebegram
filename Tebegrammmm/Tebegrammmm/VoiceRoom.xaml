                    <!--  Микрофон  -->
                    <Button
                        Width="56"
                        Height="56"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTip="Микрофон">
                        <Border
                            Width="50"
                            Height="50"
                            Background="#263241"
                            CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path
                                    Data="{StaticResource IconMic}"
                                    Fill="White"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Border>
                    </Button>


                    <!--  Добавить пользователя в звонок  -->
                    <Button
                        Width="56"
                        Height="56"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTip="Добавить нового пользователя">

                        <Border
                            Width="50"
                            Height="50"
                            Background="#263241"
                            CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path
                                    Data="{StaticResource IconPlus}"
                                    Fill="White"
                                    Stretch="Uniform" />
                            </Viewbox>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
