<Window x:Class="Tebegrammmm.VoiceRoom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tebegrammmm"
        mc:Ignorable="d"
        Background="#303c4c"
        Height="500" Width="400"
        Closing="Window_Closing">

    <Grid>

        <Grid Name="DefoultVoiceRoom" Visibility="Visible">
            <!-- Верхняя панель с эмодзи и системными кнопками -->
            <Grid Margin="0,0,0,0">
                <!--Основная разметка-->
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!--Верхняя панель-->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Username"
                               Foreground="#FFFFFF"
                               FontSize="20"/>
                </StackPanel>

                <!-- Центр -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Grid Width="190" Height="190">
                        <Ellipse Fill="#263241"/>
                        <!-- Аватарка -->
                        <Ellipse>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="https://djnkpzmq-5000.euw.devtunnels.ms/avatars/1008024429709774919.webp"
                                            Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>

                    <TextBlock Text=""
                               Foreground="#B8C2CC"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Нижняя панель с кнопками -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <!-- Видеозвонок -->
                    <!--<Button Width="56" Height="56"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="Включить видеозвонок">
                        <Border Height="50" Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconCamera}"
                              Fill="White"
                              Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>-->

                    <!-- Отмена -->
                    <Button Width="64" Height="64"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="Завершить"
                            Click="Button_Click_2">
                        <Border Height="50" Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconClose}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>

                    <!-- Завершить -->
                    <Button Width="64" Height="64"
                            Click="Button_Click_1"
                Background="Transparent"
                BorderBrush="Transparent"
                ToolTip="Завершить">
                        <Border Height="50" Width="50" 
                        Background="#263241"
                        CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconPhone}"
                              Fill="White"
                              Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Name="ActiveVoiceRoom" Visibility="Hidden">
            <!-- Верхняя панель с эмодзи и системными кнопками -->
            <Grid Margin="0,0,0,0">
                <!--Основная разметка-->
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!--Верхняя панель-->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Username"
                           Foreground="#FFFFFF"
                           FontSize="20"/>
                </StackPanel>

                <!-- Центр -->
                <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Grid Width="190" Height="190">
                        <Ellipse Fill="#263241"/>
                        <!-- Аватарка -->
                        <Ellipse>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="https://djnkpzmq-5000.euw.devtunnels.ms/avatars/1008024429709774919.webp"
                                            Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Иконка микрофона у аватарки -->
                        <Border VerticalAlignment="Bottom" 
                                HorizontalAlignment="Right" 
                                Height="50" Width="50" 
                                Background="#303c4c"
                                CornerRadius="28">
                            <Border Background="#263241" Height="45" Width="45" CornerRadius="28">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconMic}"
                                          Fill="White"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                        </Border>
                    </Grid>

                    <TextBlock Text="CallTime"

                           Foreground="#B8C2CC"
                                         FontSize="14"
           HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Нижняя панель с кнопками -->
                <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <!-- Дэмка -->
                    <Button Width="56" Height="56"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="Демонстрация экрана">
                        <Border Height="50" Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconScreenShare}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>

                    <!-- Видеозвонок -->
                    <Button Width="56" Height="56"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTip="Включить видеозвонок">
                        <Border Height="50" Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconCamera}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>

                    <!-- Завершить -->
                    <Button Width="64" Height="64"
                            Click="Button_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTip="Завершить">
                        <Border Height="50" Width="50" 
                                Background="#FF4D4F"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconPhone}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>

                    <!-- Микрофон -->
                    <Button Width="56" Height="56"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="Микрофон"
                            Click="Button_Click_3">
                        <Border Height="50" Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconMic}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>


                    <!-- Добавить пользователя в звонок -->
                    <Button Width="56" Height="56"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        ToolTip="Добавить нового пользователя">

                        <Border Height="50" 
                                Width="50" 
                                Background="#263241"
                                CornerRadius="28">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource IconPlus}"
                                      Fill="White"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
